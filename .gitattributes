# Normalize all text files to LF in the repo, working tree gets native EOL
* text=auto

# Declare binary files so git doesn't attempt line-ending conversion
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.jar binary
*.aar binary
*.apk binary
*.aab binary
*.dex binary
*.keystore binary
*.jks binary
*.db binary
*.mp4 binary
*.mp3 binary
*.ogg binary
*.ttf binary
*.otf binary
*.woff binary
*.woff2 binary

# Windows-specific files
*.bat text eol=crlf
*.cmd text eol=crlf

# Unix shell scripts
*.sh text eol=lf
gradlew text eol=lf

# Gradle
*.gradle text eol=lf
*.gradle.kts text eol=lf
gradle.properties text eol=lf

# Kotlin
*.kt text eol=lf
*.kts text eol=lf

# XML
*.xml text eol=lf
